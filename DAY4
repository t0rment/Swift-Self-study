struct Rectangle {
    var width: Double
    var height: Double

    func area() -> Double{
        return width * height
    }
}
let rectangleArea = Rectangle(width: 7.5, height: 12.0).area()

print(rectangleArea)



struct Circle {
    var radius: Double
    
    func area() -> Double{
        return Double.pi * radius * radius
    }
}
var circleaArea = Circle(radius: 4).area()
print(circleaArea)



struct BankAccount {
    var owner: String
    var balance: Double

    mutating func deposit(amount: Double) {
        balance += amount
    }

    mutating func withdraw(amount: Double) {
        balance -= amount
    }
}

var account = BankAccount(owner: "Ami", balance: 1000)

account.deposit(amount: 500)
account.withdraw(amount: 200)

print(account.balance)


