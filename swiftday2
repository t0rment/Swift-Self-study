import UIKit

func findMinimum(numbers: [Int]) -> Int{
    return numbers.min()!
}
findMinimum(numbers: [1,3,6,9])


func sum(numbers: [Int]) -> Int{
    var sumOfNumbers = 0
    for i in numbers{
        sumOfNumbers+=i
        print("The sum of current numbers is:\(sumOfNumbers)")
    }
    return sumOfNumbers
}
sum(numbers: [23,25,29])

func average(numbers: [Int]) -> Double{
    var sum = 0
    for i in numbers {
        sum += i
    }
    let avg = Double(sum) / Double(numbers.count)
    print("THE AVERAGE OF NUMBERS IS: \(avg)")
    return avg
}

average(numbers: [2,45,27,74])


func containsNumber(_ number: Int, in array: [Int]) -> Bool{
    let contains = array.contains(number)
    return contains
}
containsNumber(3, in: [3,5,7,9])

